# Project-specific ignores
# (Repo-wide ignores live in the root .gitignore — add only project-specific ones here.)

# Working artefacts (data, models, indices, experiment tracking)
data/raw/
data/processed/
data/interim/
data/vector/
mlruns/

# Env, caches, venv
.env
.venv/
__pycache__/
.pytest_cache/
.ipynb_checkpoints/

# Logs + temp files
*.log
*.tmp

# Working zips / Colab uploads — never commit these to a portfolio repo
*.zip

# Stray notebook outputs (notebooks should chdir to project root via _nb_header.py;
# if they don't, they sometimes write data here by accident — ignore preemptively)
notebooks/data/

# Model artifacts and raw data (fixtures excepted)
data/raw/
data/processed/
models/*.pkl
models/*.npy
models/*.faiss
models/*.txt
!models/sample/**
*.xlsx
!tests/fixtures/*.xlsx
